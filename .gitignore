.idea/
logs/
# Local-only camoufox build artifacts. These are fetched by deploy.sh into
# /opt/camoufox-staging at deploy time and copied into the image verbatim;
# they don't belong in git because each deploy may pin a different camoufox
# release tag or ublock/geoip version.
camofox-runtime/
# Build outputs and dependencies — generated by `npm run build` / `npm
# install` in the Dockerfile stages and shouldn't be in version control.
dist/
gateway/dist/
node_modules/
gateway/node_modules/
